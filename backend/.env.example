# ─── Echoes of the Lycan — backend (.env mẫu) ───
# Copy file này thành `.env` rồi điền giá trị thật. KHÔNG commit `.env`.

PORT=3636

# ─── Auth ví Solana (JWT) ───
JWT_SECRET=doi-thanh-secret-that
REFRESH_SECRET=doi-refresh-secret-that
REQUIRE_AUTH=0            # =1 bắt buộc đăng nhập ví mới vào được socket

# ─── LLM (GM diễn đạt + bot suy luận) ───
# ollama = local, vô hạn, miễn phí (demo) | groq = cloud nhanh nhưng quota/ngày
LLM_PROVIDER=ollama
GROQ_API_KEY=
OLLAMA_MODEL=qwen3:8b
LLM_ENABLED=0            # =1 bật LLM; =0 GM/bot dùng câu cứng (không gọi LLM)

# ─── Agora (voice + ConvoAI Quản trò) ───
AGORA_APP_ID=
AGORA_APP_CERT=
AGORA_AGENT_ENABLED=0    # =1 bật ConvoAI agent THẬT (đốt phút); =0 GM nói qua FE Web Speech
# PUBLIC_URL: có giá trị = agent dùng custom-LLM (não của mình, cần tunnel cloudflared)
#             để trống    = agent dùng LLM managed của Agora
PUBLIC_URL=

# ─── Solana (mint NFT thành tích) ───
SOLANA_CLUSTER=devnet
# SOLANA_KEYPAIR=         # secret key ví backend trả phí mint — KHÔNG commit
