{
  "name": "echoes-backend",
  "version": "2.0.0",
  "private": true,
  "description": "Echoes of the Lycan — backend (Express + TypeScript), gồm game core + AI Quản trò + Agora + Solana.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/data/migrate.ts",
    "db:seed": "tsx src/data/seed.ts",
    "db:clean": "tsx src/data/seed.ts --clean"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.3",
    "agora-token": "^2.0.5",
    "better-sqlite3": "^11.3.0",
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.0",
    "tweetnacl": "^1.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
