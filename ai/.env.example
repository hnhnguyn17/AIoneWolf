# ───────────────────────────────────────────────────────────────
# AIoneWolf — AI Quan tro (Game Master) — bien moi truong
# Copy file nay thanh `.env` roi dien gia tri that.
# ───────────────────────────────────────────────────────────────

# Cong cua tool-server (Custom-LLM proxy). Agora ConvoAI Engine se tro LLM_URL vao day.
PORT=5000

# Backend game (REST /gm/*). Mac dinh chay local.
BACKEND_URL=http://localhost:4000

# Shared secret giua ai <-> backend. Header: Authorization: Bearer <GM_SECRET>
# (xem contracts/api.md muc "AI Quan tro -> backend").
GM_SECRET=dev-gm-secret

# ───────────────────────────────────────────────────────────────
# Agora — CAN USER CUNG CAP de noi that (hien tai STUB).
# Lay tu https://console.agora.io  (Project Management).
# ───────────────────────────────────────────────────────────────
AGORA_APP_ID=
AGORA_APP_CERT=

# Nha cung cap "bo nao" LLM:
#   stub   = dung intent-parser regex tieng Viet (CHAY DUOC NGAY, khong can key)
#   openai = goi LLM that (vd gpt-4o-mini) — CAN OPENAI_API_KEY (nối sau)
LLM_PROVIDER=stub

# Chi can khi LLM_PROVIDER=openai. De trong khi dang dung stub.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
