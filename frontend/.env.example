# ─── AIoneWolf frontend (Vite) ───
# Sao chép file này thành `.env` rồi chỉnh giá trị:  cp .env.example .env

# URL backend (socket.io + REST). Mặc định backend chạy cổng 3636.
VITE_BACKEND_URL=http://localhost:3636

# Chế độ chạy:
#   =1  luồng demo tự diễn (mockServer): fill bots / skip phase / AI speak /
#       ngày-đêm — KHÔNG cần backend. Tốt để test giao diện & luồng game.
#   =0  nối backend THẬT ở VITE_BACKEND_URL (DevPanel fill-bots/skip sẽ vô tác dụng).
VITE_MOCK=1
